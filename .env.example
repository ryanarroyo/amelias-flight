# Contact form ("Send a message") — copy to .env.local for local dev,
# and set the same keys in Vercel → Project → Settings → Environment Variables.

# --- Server-side (NEVER exposed to the browser) ---
# Resend API key — https://resend.com (free tier: 3,000 emails/mo).
RESEND_API_KEY=
# Where contact messages are delivered (your inbox).
CONTACT_TO_EMAIL=you@example.com
# Verified sender. Leave unset to use Resend's onboarding sender, which can send
# to your own account email without verifying a domain.
# CONTACT_FROM="Amelia's Flight <onboarding@resend.dev>"
# Cloudflare Turnstile SECRET key — https://dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET_KEY=

# --- Client-side (public; safe to expose, must be prefixed VITE_) ---
# Cloudflare Turnstile SITE key. If unset, the form falls back to Cloudflare's
# "always passes" TEST key so local dev works; set the real key for production.
VITE_TURNSTILE_SITE_KEY=
